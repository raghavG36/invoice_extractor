# Invoice extraction – copy to .env and set values

# Pipeline A LLM: use OpenAI (default) or local Ollama
# INVOICE_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_INVOICE_MODEL=gpt-4o-mini

# Or use local Ollama (no API key needed; run: ollama serve & ollama pull llama3.2)
# INVOICE_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# Optional: Azure Computer Vision for Pipeline A OCR
# INVOICE_OCR_BACKEND=azure
# AZURE_VISION_KEY=...
# AZURE_VISION_ENDPOINT=https://....cognitiveservices.azure.com/

# Optional: custom image path (default: invoice_extractor/images/batch_1/batch_1/batch1_1)
# INVOICE_IMAGES_DIR=/path/to/batch_1/batch_1/batch1_1
